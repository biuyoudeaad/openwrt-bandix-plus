config bandix_plus 'general'
	# Service switch (read by init script)
	option enabled '1'

	# Multi-interface monitoring targets (repeat with `list iface`)
	list iface 'br-lan'
	# list iface 'pppoe-WAN'
	# list iface 'eth1.11'
	# list iface 'tailscale0'

	# Core runtime options
	option log_level 'info'
	option tc_order 'first'
	option history_window_minutes '10'
	option api_bind '127.0.0.1:8787'
	option data_dir '/usr/share/bandix-plus'
